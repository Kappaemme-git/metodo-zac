# Produzione: crea questi valori nei Project Settings di Vercel.
SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Segreti lunghi e casuali, diversi tra loro (minimo 32 caratteri).
ADMIN_PASSWORD=REPLACE_ME
ADMIN_SESSION_SECRET=REPLACE_ME_WITH_32_RANDOM_CHARACTERS
DOWNLOAD_TOKEN_SECRET=REPLACE_ME_WITH_32_RANDOM_CHARACTERS

# URL canonico del sito, senza slash finale.
SITE_ORIGIN=https://example.com

# Opzionale: hash IP giornaliero per abuso/diagnostica, mai l'IP in chiaro.
IP_HASH_SECRET=REPLACE_ME_WITH_32_RANDOM_CHARACTERS
